# ──────────────────────────────────────────────────────────────────
# MC AFK Bot — Environment Variables
# Copy this file to .env and fill in your values.
# On Pterodactyl: set these as Startup Variables in the panel instead.
# ──────────────────────────────────────────────────────────────────

# Your Discord bot token (required)
# Get it from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Restrict the bot to a single Discord server (optional but recommended)
# Right-click your server icon > Copy Server ID (Developer Mode must be on)
# Leave blank or remove this line to allow the bot in all servers.
GUILD_ID=your_discord_server_id_here
